rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /portfolio/{portfolioId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /packages/{packageId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /testimonials/{testimonialId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
